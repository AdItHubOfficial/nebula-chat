# Copy this file to ".env" for local development.
# On Render, set these as environment variables in the dashboard instead.

# Postgres connection string. Use your free Neon database URL (the same one you
# set on Render) so local dev and production share persistent data:
#   postgresql://user:pass@ep-xxx.region.aws.neon.tech/nebula?sslmode=require
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# Local backend port (kept off the Vite dev port). In production the platform's
# PORT is used automatically, so you do NOT need SERVER_PORT there.
SERVER_PORT=4000

# Secret used to sign JWT access tokens. Use a long random string in production.
JWT_SECRET="change_me_to_a_long_random_string"
JWT_EXPIRES_IN="7d"

# Where uploads are stored (relative to project root)
UPLOAD_DIR="uploads"

# Client origin allowed by CORS (Vite dev server)
CLIENT_ORIGIN="http://localhost:5173"
